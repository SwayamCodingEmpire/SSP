# ============================================================
# SSP Environment Variables — copy to .env and fill in values
# ============================================================

# AI Provider API Keys
OPEN_AI_API_KEY=
ANTHROPIC_API_KEY=

# Database
DB_URL=jdbc:postgresql://localhost:5432/ssp?characterEncoding=UTF-8
DB_USERNAME=postgres
DB_PASSWORD=

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:4200